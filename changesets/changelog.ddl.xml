            <column name="EMAIL_ADDRESS" value="taylor.morgan2@example.com"/>
            <where>ID = 1</where>
        </update>
        <rollback>
            <update tableName="EMPLOYEES">
                <column name="EMAIL_ADDRESS" value="redacted@example.com"/>
                <where>ID = 1</where>
            </update>
        </rollback>
    </changeSet>

    <changeSet id="dcl_grant_employee_guest" author="mikeo" labels="jira-1412,release-1.0.3">
        <sql>GRANT SELECT ON EMPLOYEES TO guest</sql>
        <rollback>
            <sql>REVOKE SELECT ON EMPLOYEES FROM guest</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>