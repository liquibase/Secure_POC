    <!-- ********** Release 1.0.2 ********** -->

    <changeSet id="ddl_create_fk_employees" author="molivas" labels="release-1.0.2">
        <addForeignKeyConstraint
            constraintName="ORG_FK2"
            baseTableName="EMPLOYEES"
            baseColumnNames="ORG_ID"
            referencedTableName="ORGANIZATIONS"
            referencedColumnNames="ID"/>
    </changeSet>

    <changeSet id="dml_delete_organizations" author="jbennett" labels="release-1.0.2">
        <sql>DELETE FROM ORGANIZATIONS</sql>
        <rollback/>
    </changeSet>

    <changeSet id="sp_create_getemployeesbyorg" author="molivas" labels="release-1.0.2" runOnChange="true">
        <sql splitStatements="false">
            CREATE OR REPLACE FUNCTION get_employees_by_org(p_org_id integer)
            RETURNS TABLE (
                ID integer,
                FIRST_NAME varchar,
                LAST_NAME varchar,
                DATE_OF_BIRTH date
            ) AS $$
            BEGIN
                RETURN QUERY
                SELECT e.ID, e.FIRST_NAME, e.LAST_NAME, e.DATE_OF_BIRTH
                FROM EMPLOYEES e
                WHERE e.ORG_ID = p_org_id;
            END;
            $$ LANGUAGE plpgsql;
        </sql>
        <rollback>
            <sql>DROP FUNCTION IF EXISTS get_employees_by_org(integer)</sql>
        </rollback>
    </changeSet>

    <!-- ********** Release 1.0.3 ********** -->

    <changeSet id="dml_email_fix" author="jbennett" labels="jira-1388,release-1.0.3">
